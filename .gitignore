# ============================================================================
# PORTFOLIO GITIGNORE - SECURITY & PERFORMANCE OPTIMIZED
# ============================================================================
# This file prevents sensitive data, large files, and build artifacts from
# being committed to the repository. Organized by category for maintainability.
# ============================================================================

# ============================================================================
# CREDENTIALS & SECRETS (CRITICAL SECURITY)
# ============================================================================
# Never commit credentials, API keys, certificates, or private keys
# These patterns catch common credential file formats

# Environment variables
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# Certificates and keys
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt
*_rsa
*_dsa
*_ecdsa
*_ed25519

# Secret directories
secrets/
.secrets/
credentials/
.credentials/
*.secret
*.private

# Package manager auth
.npmrc
.yarnrc
auth.json

# ============================================================================
# NODE.JS / JAVASCRIPT
# ============================================================================
# Dependencies and build artifacts for Node.js projects

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/

# Testing
coverage/
.nyc_output/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Cache directories
.cache/
.temp/
.eslintcache
.stylelintcache

# ============================================================================
# PYTHON
# ============================================================================
# Python bytecode, virtual environments, and build artifacts

# Bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.Python
venv/
ENV/
env/
.venv

# Distribution / packaging
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg

# Testing and coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb_checkpoints

# Package management
pip-log.txt
pip-delete-this-directory.txt
Pipfile.lock

# ============================================================================
# C++ BUILD ARTIFACTS
# ============================================================================
# Compiled object files and build directories

# Compiled Object files
*.o
*.obj
*.slo
*.lo
*.ko

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Build directories
/build/
/Build/
/cmake-build-*/
CMakeFiles/
CMakeCache.txt

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.so
*.dylib
*.dll

# ============================================================================
# ASTRO FRAMEWORK
# ============================================================================
# Astro-specific build artifacts and cache

.astro/

# ============================================================================
# IDE & EDITORS
# ============================================================================
# Configuration files for various IDEs and text editors

# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr
.fleet/

# Sublime Text
.sublime-project
.sublime-workspace

# Vim
*.swp
*.swo
*~

# Visual Studio
.vs/

# ============================================================================
# AI AGENTS & DEVELOPMENT TOOLS
# ============================================================================
# Configuration for AI coding assistants and development tools

.kiro/
.agents/
.claude/
skills-lock.json
.cursor/
.windsurf/
*.agent.json
*-agent.md
AGENT.md
protocolo_*.md

# ============================================================================
# DOCUMENTATION (INTERNAL)
# ============================================================================
# Exclude internal documentation, keep essential public docs
# This prevents documentation bloat in the repository

*.md
!README.md
!LICENSE.md
!SECURITY.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!CHANGELOG.md

# ============================================================================
# DATA FILES & LARGE ASSETS
# ============================================================================
# Prevent large data files from bloating the repository
# Exceptions are made for small sample datasets

# Databases
*.db
*.sqlite
*.sqlite3
*.sql
dump.*.sql

# Spreadsheets and data files
*.csv
*.xlsx
*.xls
!Proyectos/**/datos/*.csv  # Allow small sample datasets

# Compressed archives
*.zip
*.tar
*.gz
*.7z
*.rar
*.bz2

# ============================================================================
# MULTIMEDIA FILES
# ============================================================================
# Large media files should be stored externally (CDN, Git LFS, etc.)

# Videos
*.mp4
*.avi
*.mov
*.wmv
*.flv
*.mkv
*.webm

# Large image formats
*.psd
*.ai
*.sketch
*.fig

# ============================================================================
# PROJECT-SPECIFIC LARGE FILES
# ============================================================================
# Specific directories known to contain large files

# Power BI files (typically >100MB)
**/*.pbix
**/Desarrollo.pbix
public/Proyectos/**/*.pbix
Proyectos/dashboards/*.pbix

# Large database directories
Proyectos/**/DB/
Proyectos/**/Datos en si/
public/Proyectos/**/DB/
public/Proyectos/**/Datos en si/

# HTML exports from Jupyter notebooks (can be regenerated)
public/notebooks-html/*.html
notebooks-html/*.html
dist/notebooks-html/*.html

# Large notebooks
public/notebooks/*.ipynb
public/notebooks/Copia de DeepDreams.ipynb
dist/notebooks/*.ipynb

# Large datasets in specific projects
Proyectos/**/Datos en si/*.csv
public/Proyectos/**/Datos en si/*.csv

# TensorFlow and ML model checkpoints
**/*.ckpt
**/*.data-00000-of-00001
**/*.index
**/*.meta
**/checkpoint
**/_pywrap_tensorflow_*.dll
**/site-packages/tensorflow/
**/site-packages/cv2/

# ============================================================================
# LARGE PROJECT DIRECTORIES
# ============================================================================
# Entire project directories that are too large for GitHub
# These should be stored in Git LFS or external storage

Proyectos/PrediccionImagenes/
Proyectos/PredicePrecioAcciones/
Proyectos/Redes-Convolucionales/
Proyectos/Redes-Generativas-Adversariales/
Proyectos/Regresion_Lineal/
Proyectos/TITANIC-Arbol_de_Decision/
Proyectos/Warriors-Games/
public/Proyectos/PrediccionImagenes/
public/Proyectos/PredicePrecioAcciones/
public/Proyectos/Redes-Convolucionales/
public/Proyectos/Redes-Generativas-Adversariales/
public/Proyectos/Regresion_Lineal/
public/Proyectos/TITANIC-Arbol_de_Decision/
public/Proyectos/Warriors-Games/

# ============================================================================
# GIT INTERNALS
# ============================================================================
# Prevent accidental commits of git internal files

.git/modules/
.git/objects/pack/*.pack
.git/objects/pack/*.idx
*.submodule

# ============================================================================
# OPERATING SYSTEM FILES
# ============================================================================
# OS-generated files that should not be versioned

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================================================
# TEMPORARY & BACKUP FILES
# ============================================================================
# Temporary files and backups created by various tools

*.tmp
*.temp
*.bak
*.backup
*.old
*.swp
*.swo
*~

# ============================================================================
# BUILD & DEPLOYMENT ARTIFACTS
# ============================================================================
# Files generated during build and deployment processes

# Build metadata
public/notebooks/
!public/notebooks/.gitkeep

# README sync outputs
scripts/readme-updates/
!scripts/readme-updates/.gitkeep

# Mercury framework
.mercury/

# Logs
logs/
*.log

# ============================================================================
# MISCELLANEOUS
# ============================================================================
# Other files that should not be committed

# Misc
.DS_Store
*.pem

# ============================================================================
# END OF GITIGNORE
