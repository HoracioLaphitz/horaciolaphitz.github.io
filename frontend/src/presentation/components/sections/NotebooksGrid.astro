---
import NotebookProjectCard from './NotebookProjectCard.astro';
import type { Props as CardProps } from './NotebookProjectCard.astro';

export type { Props as NotebookProjectCardProps } from './NotebookProjectCard.astro';

export interface Props {
  projects: CardProps[];
}
const { projects } = Astro.props;
const count = projects.length;
---

<section class="py-4xl px-4">
  <div class="container">
    <div class="mb-4xl">
      <h2 class="text-4xl font-bold mb-lg text-text-primary">Notebooks Interactivos</h2>
      <p class="text-text-secondary text-base">
        {count} proyecto{count !== 1 ? 's' : ''} encontrado{count !== 1 ? 's' : ''}
      </p>
    </div>

    {count === 0 ? (
      <div class="text-center py-4xl">
        <p class="text-text-secondary text-base">No se encontraron proyectos.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-lg">
        {projects.map((project) => (
          <NotebookProjectCard {...project} />
        ))}
      </div>
    )}
  </div>
</section>
