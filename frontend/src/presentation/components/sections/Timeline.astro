---
export interface ExperienceItem {
  period: string;
  role: string;
  company: string;
  description: string;
  location: string;
}

export interface Props {
  experiences?: ExperienceItem[];
}

const { experiences = [] } = Astro.props;

const displayEvents =
  experiences.length > 0
    ? experiences.map((e) => ({
        period: e.period,
        title: e.role,
        company: e.company,
        description: e.description,
        location: e.location,
      }))
    : [];
---

<section id="experiencia" class="py-4xl md:py-5xl px-4">
  <div class="container">
    <div class="section-header animate-fade-in-up">
      <h2>Experiencia Laboral</h2>
    </div>

    <div class="max-w-3xl mx-auto space-y-md animate-fade-in-up animate-delay-200">
      {
        displayEvents.length === 0 ? (
          <div class="text-center py-4xl glass rounded-2xl">
            <p style="color: var(--color-text-secondary);">No hay experiencias registradas.</p>
          </div>
        ) : (
          displayEvents.map((event, index) => (
            <div
              class="glass rounded-xl p-xl glass-hover animate-fade-in-up"
              style={`animation-delay: ${200 + index * 100}ms`}
            >
              <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
                <span class="chip">{event.period}</span>
                {event.location && (
                  <span class="text-xs font-medium" style="color: var(--color-text-tertiary);">
                    {event.location}
                  </span>
                )}
              </div>
              <h3 class="text-xl font-semibold mb-1" style="color: var(--color-text-primary);">
                {event.title}
              </h3>
              {event.company && (
                <p class="text-sm font-medium mb-2" style="color: var(--color-accent);">
                  {event.company}
                </p>
              )}
              <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                {event.description}
              </p>
            </div>
          ))
        )
      }
    </div>
  </div>
</section>
