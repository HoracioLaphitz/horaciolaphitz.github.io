---
export interface ExperienceItem {
  period: string;
  role: string;
  company: string;
  description: string;
  location: string;
}

export interface Props {
  experiences?: ExperienceItem[];
}

const { experiences = [] } = Astro.props;

const fallbackEvents = [
  { period: '2020', title: 'Inicio en Data Analytics', company: '', description: 'Comenzó mi carrera en análisis de datos', location: '' },
  { period: '2022', title: 'Especialización en Visualización', company: '', description: 'Profundizó en técnicas de visualización avanzada', location: '' },
  { period: '2024', title: 'Full Stack Development', company: '', description: 'Expandió habilidades hacia desarrollo web completo', location: '' },
];

const displayEvents = experiences.length > 0
  ? experiences.map(e => ({ period: e.period, title: e.role, company: e.company, description: e.description, location: e.location }))
  : fallbackEvents;
---

<section id="experiencia" class="py-4xl px-4 relative overflow-hidden" style="background-color: var(--color-surface-elevated);">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, transparent, var(--color-accent), transparent); opacity: 0.15;" />
  </div>
  <div class="container relative">
    <h2 class="text-4xl font-bold mb-4xl text-center" style="color: var(--color-text-primary);">
      Experiencia
    </h2>
    <div class="max-w-2xl mx-auto space-y-lg">
      {displayEvents.map((event, index) => (
        <div class="relative animate-fade-in-up" style={`animation-delay: ${index * 150}ms`}>
          <div
            class="relative p-lg md:p-xl rounded-2xl border border-border transition-all duration-300 hover:shadow-md"
            style="background-color: var(--color-surface);"
          >
            <div class="absolute left-0 top-0 bottom-0 w-[3px] rounded-full" style="background: linear-gradient(to bottom, var(--color-accent), var(--color-accent), transparent);" />
            <div class="flex flex-wrap items-start justify-between gap-sm mb-2">
              <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold text-accent" style="background-color: var(--color-accent-muted);">
                <span class="w-1.5 h-1.5 rounded-full bg-accent" />
                {event.period}
              </span>
              {event.location && (
                <span class="text-xs" style="color: var(--color-text-tertiary);">{event.location}</span>
              )}
            </div>
            <h3 class="text-xl font-semibold mb-0.5" style="color: var(--color-text-primary);">{event.title}</h3>
            {event.company && (
              <p class="text-sm font-medium text-accent mb-3">{event.company}</p>
            )}
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">{event.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
