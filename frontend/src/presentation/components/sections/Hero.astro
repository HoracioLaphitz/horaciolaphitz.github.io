---
export interface Props {
  name?: string;
  role?: string;
  description?: string;
}

const { name = 'Horacio Laphitz', role = 'Analista de Datos', description } = Astro.props;
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#050b11] px-4 py-10 text-[#d7ffb7]"
>
  <div
    class="relative z-10 mx-auto w-full max-w-4xl overflow-hidden rounded-[2rem] border border-[#1b2838] bg-[#08101a]/95 shadow-[0_35px_90px_-40px_rgba(34,255,138,0.35)]"
  >
    <div class="flex items-center gap-3 border-b border-[#12202e] bg-[#061118]/95 px-5 py-4">
      <span class="h-3 w-3 rounded-full bg-[#ff5f56]"></span>
      <span class="h-3 w-3 rounded-full bg-[#ffbd2e]"></span>
      <span class="h-3 w-3 rounded-full bg-[#27c93f]"></span>
      <span class="ml-auto text-xs uppercase tracking-[0.4em] text-[#7ef9b4]">console</span>
    </div>

    <div class="px-6 py-10 md:px-10">
      <div class="mb-8 space-y-3">
        <p class="text-sm uppercase tracking-[0.35em] text-[#74f1a4]">
          ╔══════════════════════════════════════════════╗
        </p>
        <p class="text-4xl font-semibold tracking-tight text-[#eeffd2]">{name}</p>
        <p class="text-base text-[#9ef4b8]">{role}</p>
      </div>

      <div
        class="space-y-4 rounded-[1.75rem] border border-[#172335] bg-[#071018]/95 p-6 font-mono text-sm leading-7 text-[#c8ffb8] shadow-inner"
      >
        <div class="space-y-2">
          <p><span class="text-[#7ef9b4]">&gt; Class Porfolio:</span></p>
          <p>
            <span class="text-[#7ef9b4]">└─</span> self._usuario = <span class="text-[#f7ffd3]"
              >"{name}"</span
            >
          </p>
          <p>
            <span class="text-[#7ef9b4]">└─</span> self._rol = <span class="text-[#f7ffd3]"
              >"{role}"</span
            >
          </p>
        </div>

        {
          description && (
            <div class="space-y-2">
              <p class="text-[#7ef9b4]">&gt; self.descripcion</p>
              <p class="whitespace-pre-wrap text-[#e9f9c8]">{description}</p>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
