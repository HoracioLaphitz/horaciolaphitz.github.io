---
export interface Badge {
  src: string;
  alt: string;
}

export interface Props {
  aboutDescription?: string | string[];
  skillGroups?: Record<string, string[]>;
  avatar?: string;
  badges?: Badge[];
  name?: string;
}

const { aboutDescription, skillGroups = {}, avatar, badges = [], name } = Astro.props;

const paragraphs = Array.isArray(aboutDescription) ? aboutDescription : (aboutDescription ? [aboutDescription] : []);
---

<section class="py-4xl md:py-5xl px-4">
  <div class="container">
    <div class="section-header animate-fade-in-up">
      <span class="chip mb-4">Sobre mí</span>
      <h2>Perfil</h2>
      <p>Data Analyst con experiencia en sistemas de gestión, automatización y visualización</p>
    </div>

    <div
      class="grid gap-2xl lg:grid-cols-[320px_minmax(0,1fr)] items-start animate-fade-in-up animate-delay-200"
    >
      {
        avatar && (
          <div class="space-y-6">
            <div class="glass rounded-2xl p-lg text-center">
              <img
                src={avatar}
                alt={name || 'Avatar de perfil'}
                width={320}
                height={320}
                loading="lazy"
                decoding="async"
                class="w-full max-w-[240px] mx-auto rounded-xl object-cover shadow-lg"
                style="aspect-ratio: 1;"
              />
            </div>

            {badges.length > 0 && (
              <div class="grid gap-3 sm:grid-cols-2">
                {badges.map((badge) => (
                  <div class="glass rounded-xl p-3">
                    <img
                      src={badge.src}
                      alt={badge.alt}
                      class="h-32 w-full object-contain"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                ))}
              </div>
            )}
          </div>
        )
      }

      <div class="space-y-8">
        {
          paragraphs.length > 0 && (
            <div class="glass rounded-2xl p-xl space-y-4">
              {paragraphs.map((p) => (
                <p class="leading-relaxed" style="color: var(--color-text-secondary);">
                  {p}
                </p>
              ))}
            </div>
          )
        }

        {
          Object.keys(skillGroups).length > 0 && (
            <div class="space-y-lg">
              {Object.entries(skillGroups).map(([category, categorySkills]) => (
                <div>
                  <h4
                    class="text-sm font-semibold mb-3 uppercase tracking-wider"
                    style="color: var(--color-text-tertiary);"
                  >
                    {category}
                  </h4>
                  <div class="flex flex-wrap gap-2">
                    {categorySkills.map((skill) => (
                      <span class="chip">{skill}</span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
