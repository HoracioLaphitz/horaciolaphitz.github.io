<section id="servicios" class="py-3xl md:py-4xl lg:py-5xl px-2 sm:px-4">
  <div class="container">
    <div class="section-header animate-fade-in-up">
      <span class="chip mb-4">Servicios</span>
      <h2>Qué puedo resolver</h2>
      <p>Datos, modelos predictivos, automatización y tableros para decisiones basadas en evidencia.</p>
    </div>

    <div class="grid gap-lg sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 animate-fade-in-up animate-delay-200">
      {
        services.map((service, index) => (
          <div
            class="glass rounded-2xl p-xl glass-hover animate-fade-in-up"
            style={`animation-delay: ${200 + index * 100}ms`}
          >
            <div
              class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl"
              style="background-color: var(--color-accent-muted); color: var(--color-accent);"
            >
              <svg
                class="w-6 h-6"
                stroke="currentColor"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[service.icon]} />
              </svg>
            </div>

            <h3 class="text-xl font-semibold mb-3" style="color: var(--color-text-primary);">
              {service.title}
            </h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
