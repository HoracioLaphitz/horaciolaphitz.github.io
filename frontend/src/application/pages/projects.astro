---
import PageLayout from '@presentation/layouts/PageLayout.astro';
import { ProjectCategories } from '@presentation/components/sections/ProjectCategories';
import { container } from '@shared/di/Container';

const projectService = container.getProjectService();
const proyectos = await projectService.getAllProjects();

const proyectosSerializados = proyectos.map((p) => ({
  slug: p.slug,
  title: p.title,
  description: p.description,
  category: p.category,
  tags: [],
  publishDate: p.createdAt.toISOString(),
  author: 'Horacio',
  githubUrl: p.github_url,
  dashboardUrl: p.demo_url,
  status: p.status,
  featured: p.featured,
}));
---

<PageLayout
  title="Proyectos"
  description="Explora mis proyectos de análisis de datos y visualización."
>
  <ProjectCategories posts={proyectosSerializados} client:visible />
</PageLayout>
