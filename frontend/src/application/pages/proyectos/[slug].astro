---
import ArticleLayout from '@presentation/layouts/ArticleLayout.astro';
import { ResourceDownload } from '@presentation/components/proyectos/ResourceDownload';
import { container } from '@shared/di/Container';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/proyectos');
}

const projectService = container.getProjectService();
const proyecto = await projectService.getProjectBySlug(slug);

if (!proyecto) {
  return Astro.redirect('/proyectos');
}
---

<ArticleLayout
  title={proyecto.title}
  description={proyecto.description}
  category={proyecto.category}
  author="Horacio"
  github={proyecto.github_url}
  dashboard={proyecto.demo_url}
>
  <div>
    <p class="text-lg mb-lg">{proyecto.description}</p>

    {
      proyecto.technologies && proyecto.technologies.length > 0 && (
        <div class="mb-lg">
          <h3 class="font-semibold mb-md">Tecnologías</h3>
          <div class="flex flex-wrap gap-sm">
            {proyecto.technologies.map((tech) => (
              <span class="px-md py-sm bg-light-border dark:bg-dark-border rounded-lg text-sm">
                {tech.name}
              </span>
            ))}
          </div>
        </div>
      )
    }

    <ResourceDownload client:load />
  </div>
</ArticleLayout>
