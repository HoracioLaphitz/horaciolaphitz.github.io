---
import PageLayout from '@presentation/layouts/PageLayout.astro';
import { ProjectsGrid } from '@presentation/components/sections/ProjectsGrid';
import { getProjects } from '../lib/data/getProjects';

const projects = getProjects();

const DRIVE_PROYECTOS_URL =
  'https://drive.google.com/drive/folders/1cO8ReGXlIcmQHIvsN_YmRjPP_rj1knFj';
---

<PageLayout
  title="Proyectos y Análisis"
  description="Portfolio profesional de análisis de datos, ingeniería y machine learning."
>
  <section class="pt-4xl md:pt-5xl px-4">
    <div class="container">
      <div class="section-header animate-fade-in-up">
        <span class="chip mb-4">Portfolio</span>
        <h2>Proyectos y Análisis</h2>
        <p>Proyectos de análisis de datos, machine learning e ingeniería.</p>
      </div>

      <div class="max-w-3xl mx-auto mt-lg mb-4xl animate-fade-in-up animate-delay-100">
        <a
          href={DRIVE_PROYECTOS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-lg py-md rounded-xl text-sm font-semibold transition-all duration-200 hover:scale-[1.02]"
          style="background-color: var(--color-accent); color: var(--color-text-inverse);"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
          </svg>
          Documentación en Google Drive
        </a>
      </div>
    </div>
  </section>

  <ProjectsGrid projects={projects} />
</PageLayout>
