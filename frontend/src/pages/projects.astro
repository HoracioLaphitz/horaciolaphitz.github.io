---
import { getCollection } from 'astro:content';
import PageLayout from '@presentation/layouts/PageLayout.astro';
import { ProjectsGrid } from '@presentation/components/sections/ProjectsGrid';

const entries = await getCollection('proyectos');
const proyectos = entries.map((entry) => ({
  slug: entry.slug,
  title: entry.data.title,
  description: entry.data.description,
  category: entry.data.category,
  featured: entry.data.featured,
  status: entry.data.status,
  technologies: entry.data.technologies.map((t: string) => ({ name: t })),
}));
---

<PageLayout
  title="Proyectos"
  description="Explora mis proyectos de análisis de datos, machine learning e inteligencia de negocio."
  currentPath="/projects"
>
  <ProjectsGrid projects={proyectos} client:visible showFilters={true} />
</PageLayout>
