---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ArticleLayout from "@presentation/layouts/ArticleLayout.astro";

export async function getStaticPaths() {
  const proyectos = await getCollection('proyectos');
  return proyectos.map((entry: CollectionEntry<'proyectos'>) => ({
    params: { slug: entry.id.replace(/\.\w+$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'proyectos'> };
const { Content } = await render(entry);

const tags = entry.data.technologies;
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  category={entry.data.category}
  pubDate={entry.data.createdAt}
  tags={tags}
  github={entry.data.githubUrl}
  dashboard={entry.data.demoUrl}
>
  <Content />
</ArticleLayout>
