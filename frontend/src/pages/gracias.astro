---
import PageLayout from "@presentation/layouts/PageLayout.astro";
---

<PageLayout title="¡Gracias!" description="Mensaje enviado correctamente.">
  <section class="min-h-[80vh] flex items-center justify-center px-4">
    <div class="text-center max-w-2xl mx-auto animate-fade-in-up">
      <div class="text-6xl mb-xl font-bold tracking-tight" style="color: var(--color-text-primary);">
        ¡Gracias!
      </div>
      <p class="text-xl mb-4xl leading-relaxed" style="color: var(--color-text-secondary);">
        He recibido tu mensaje y te responderé lo antes posible.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-xl py-md rounded-xl font-semibold text-base transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]"
        style="background-color: var(--color-accent); color: var(--color-text-inverse);"
      >
        Volver al inicio
      </a>
    </div>
  </section>
</PageLayout>
