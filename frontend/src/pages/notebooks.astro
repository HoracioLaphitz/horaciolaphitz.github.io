---
import PageLayout from '@presentation/layouts/PageLayout.astro';
import { ProjectsGrid } from '@presentation/components/sections/ProjectsGrid';
import { getProjects } from '../lib/data/getProjects';

const analysisProjects = getProjects().filter(p => p.type === 'analysis');
---

<PageLayout
  title="Análisis de Datos"
  description="Análisis exploratorios, modelos predictivos y visualización de datos."
  currentPath="/notebooks"
>
  <ProjectsGrid projects={analysisProjects} />
</PageLayout>
