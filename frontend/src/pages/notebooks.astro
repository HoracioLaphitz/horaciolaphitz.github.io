---
import PageLayout from '@presentation/layouts/PageLayout.astro';
import NotebooksGrid from '@presentation/components/sections/NotebooksGrid.astro';
import { getNotebooks } from '../lib/data/getNotebooks';

const notebooks = getNotebooks();
---

<PageLayout
  title="Notebooks Interactivos"
  description="Explora mis notebooks interactivos de análisis de datos y machine learning"
  currentPath="/notebooks"
>
  <NotebooksGrid projects={notebooks} />
</PageLayout>
