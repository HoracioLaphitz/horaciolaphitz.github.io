---
import PageLayout from '@presentation/layouts/PageLayout.astro';
import Timeline from '@presentation/components/sections/Timeline.astro';
import { getExperiences } from '../lib/data/getExperience';
import { getSkills } from '../lib/data/getProfile';
---

<PageLayout title="Experiencia" description="Trayectoria profesional en datos y desarrollo.">
  <Timeline experiences={getExperiences()} />

  <section class="py-4xl md:py-5xl px-4">
    <div class="container">
      <div class="section-header animate-fade-in-up animate-delay-200">
        <span class="chip mb-4">Habilidades</span>
        <h2>Tecnologías</h2>
        <p>Herramientas que uso en el día a día.</p>
      </div>

      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-md animate-fade-in-up animate-delay-300">
        {getSkills().map((skill: string, index: number) => (
          <div
            class="glass rounded-xl p-lg glass-hover animate-fade-in-up"
            style={`animation-delay: ${Math.min(300 + index * 50, 700)}ms`}
          >
            <p class="text-sm font-medium" style="color: var(--color-text-primary);">{skill}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
