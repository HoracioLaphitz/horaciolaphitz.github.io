---
import PageLayout from '@presentation/layouts/PageLayout.astro';
import { Timeline } from '@presentation/components/sections/Timeline.tsx';
import { PROFILE_DATA } from '@data/profile-data';
---

<PageLayout
  title="Experiencia Profesional"
  description="Mi trayectoria profesional como Data Analyst y desarrollador."
>
  <div class="container py-5xl">
    <div class="max-w-4xl mx-auto">
      <!-- Header Section -->
      <div class="text-center mb-4xl opacity-0 animate-fade-in-down">
        <h1
          class="text-5xl md:text-6xl font-bold mb-lg bg-gradient-to-r from-light-text-primary to-light-text-secondary dark:from-dark-text-primary dark:to-dark-accent-cyan bg-clip-text text-transparent"
        >
          Experiencia Profesional
        </h1>
        <p
          class="text-xl text-light-text-secondary dark:text-dark-text-secondary max-w-2xl mx-auto"
        >
          Mi trayectoria en análisis de datos, desarrollo y visualización
        </p>
      </div>

      <!-- Timeline Component -->
      <div class="opacity-0 animate-fade-in-up animate-delay-200">
        <Timeline client:visible experiences={PROFILE_DATA.experiences} />
      </div>

      <!-- Skills Section -->
      <div class="mt-5xl opacity-0 animate-fade-in-up animate-delay-400">
        <h2 class="text-3xl font-bold mb-xl text-center">Habilidades Técnicas</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-lg">
          {
            PROFILE_DATA.skills?.map((skill: string, index: number) => (
              <div
                class={`p-lg rounded-lg bg-light-surface dark:bg-dark-surface border border-light-border dark:border-dark-border hover:border-dark-accent-cyan dark:hover:border-dark-accent-cyan transition-all duration-300 hover-lift opacity-0 animate-fade-in-up animate-delay-${Math.min(600 + index * 50, 800)}`}
              >
                <p class="text-base font-medium text-light-text-primary dark:text-dark-text-primary">
                  {skill}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</PageLayout>
