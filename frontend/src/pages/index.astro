---
import PageLayout from '@presentation/layouts/PageLayout.astro';
import Hero from '@presentation/components/sections/Hero.astro';
import About from '@presentation/components/sections/About.astro';
import Timeline from '@presentation/components/sections/Timeline.astro';
import Services from '@presentation/components/sections/Services.astro';
import { ProjectsGrid } from '@presentation/components/sections/ProjectsGrid';
import { Contact } from '@presentation/components/sections/Contact.tsx';
import { getProjects } from '../lib/data/getProjects';
import { getProfile, getSkills, getContactInfo } from '../lib/data/getProfile';
import { getExperiences } from '../lib/data/getExperience';

const projects = getProjects();
const profile = getProfile();
const skills = getSkills();
const experiences = getExperiences();
const contactInfo = getContactInfo();
---

<PageLayout title="Portfolio" description="Data Analyst & Visualization Expert.">
  <Hero name={profile.name} role={profile.role} description={profile.descriptions[0]} />
  <About
    avatar="/img/profile.png"
    aboutDescription={profile.descriptions_about?.[0]}
    badges={[
      { src: '/img/PythonForDataScienceAndAI.png', alt: 'Insignia Python Data Science' },
      {
        src: '/img/PythonProjectForDataEngineering.png',
        alt: 'Insignia Proyecto Python Data Engineering',
      },
    ]}
    skills={skills}
    name={profile.name}
  />
  <ProjectsGrid projects={projects} client:visible compact />
  <Services />
  <Timeline experiences={experiences} />
  <Contact client:visible contactInfo={contactInfo} />
</PageLayout>
