---
import ArticleLayout from "@presentation/layouts/ArticleLayout.astro";
import { GitHubApiRepository } from "@infrastructure/repositories/github-api.repository";
import { marked } from "marked";
import { HIDDEN_PROJECT_SLUGS } from "@shared/constants/projects.config";
import { sanitizeReadmeText } from "@shared/utils/sanitizeReadme";

export async function getStaticPaths() {
  const githubRepo = new GitHubApiRepository("HoracioLaphitz");
  const proyectos = await githubRepo.findAll();

  // Same filter as index and projects pages
  const visibleRepos = proyectos.filter(
    (p) =>
      !HIDDEN_PROJECT_SLUGS.has(p.slug) &&
      !p.title.toLowerCase().includes("portfolio") &&
      !p.slug.includes("porfolio") &&
      !p.slug.includes("horaciolaphitz")
  );

  return visibleRepos.map((proyecto) => ({
    params: { slug: proyecto.slug },
    props: { proyecto },
  }));
}

interface Props {
  proyecto: import("@domain/entities/project.entity").ProjectEntity;
}

const { proyecto } = Astro.props;
const githubRepo = new GitHubApiRepository("HoracioLaphitz");

// Extract repo name from GitHub URL (e.g. "HoracioLaphitz/MarketBasketAnalytics")
const repoName = proyecto.githubUrl?.split("/").pop() || proyecto.slug;

// Fetch, sanitize, and render README
const readmeRaw = await githubRepo.getRepoReadme(repoName);
const readmeSanitized = readmeRaw ? sanitizeReadmeText(readmeRaw) : null;
const readmeHtml = readmeSanitized ? await marked.parse(readmeSanitized) : null;
---

<ArticleLayout
  title={proyecto.title}
  description={proyecto.description}
  category={proyecto.category}
  pubDate={proyecto.publishDate}
  tags={[...proyecto.tags]}
  author={proyecto.author}
  github={proyecto.githubUrl}
  dashboard={proyecto.dashboardUrl}
  currentPath={`/proyectos/${proyecto.slug}`}
>
  {
    readmeHtml ? (
      <div set:html={readmeHtml} />
    ) : (
      <p class="text-skin-muted text-center py-12">
        Este repositorio no tiene un README disponible.
      </p>
    )
  }
</ArticleLayout>
