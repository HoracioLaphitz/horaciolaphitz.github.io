---
import { getCollection } from "astro:content";
import PageLayout from "@presentation/layouts/PageLayout.astro";
import { slugify } from "@shared/slugify";

export async function getStaticPaths() {
  const proyectos = await getCollection("proyectos");
  const paths = [];

  for (const proyecto of proyectos) {
    const notebooks = proyecto.data.resources?.notebooks ?? [];
    for (const notebook of notebooks) {
      paths.push({
        params: { slug: proyecto.slug, notebook: slugify(notebook.name) },
        props: { proyecto, notebook },
      });
    }
  }

  return paths;
}

const { proyecto, notebook } = Astro.props;
const iframeSrc = `/notebooks-html/${proyecto.slug}/${slugify(notebook.name)}.html`;
---

<PageLayout
  title={`${notebook.name} — ${proyecto.data.title}`}
  description={notebook.description ?? proyecto.data.description}
  currentPath={`/proyectos/${proyecto.slug}/notebook/${slugify(notebook.name)}`}
>
  <div class="max-w-5xl mx-auto px-4 py-6">
    <a
      href={`/proyectos/${proyecto.slug}`}
      class="inline-flex items-center gap-2 text-sm font-medium text-skin-muted hover:text-skin-accent mb-4"
    >
      ← Volver al proyecto
    </a>
    <h1 class="text-2xl font-bold text-skin-primary mb-4">{notebook.name}</h1>
    <iframe
      src={iframeSrc}
      title={notebook.name}
      sandbox="allow-same-origin"
      class="w-full border border-skin-border rounded-lg"
      style="height: 80vh;"
    />
  </div>
</PageLayout>
