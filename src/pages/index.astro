---
import PageLayout from "@presentation/layouts/PageLayout.astro";
import Hero from "@presentation/components/sections/Hero";
import Timeline from "@presentation/components/sections/Timeline";
import Services from "@presentation/components/sections/Services";
import ProjectCategories from "@presentation/components/sections/ProjectCategories";
import Contact from "@presentation/components/sections/Contact";
import { GitHubApiRepository } from "@infrastructure/repositories/github-api.repository";
import { ProjectCategory } from "@domain/entities/project.entity";

// Fetch projects from GitHub API, only data analysis related
const githubRepo = new GitHubApiRepository("HoracioLaphitz");
const proyectos = await githubRepo.findAll();

// Filter to show only Data Analysis projects (exclude portfolio sites and web dev)
const proyectosDataAnalysis = proyectos.filter(
  (p) =>
    p.category === ProjectCategory.DataAnalysis &&
    !p.title.toLowerCase().includes("portfolio") &&
    !p.title.toLowerCase().includes("horaciolaphitz.github.io")
);

// Serialize for client
const proyectosSerializados = proyectosDataAnalysis.map((p) => ({
  slug: p.slug,
  title: p.title,
  description: p.description,
  category: p.category,
  tags: [...p.tags],
  publishDate: p.publishDate.toISOString(),
  author: p.author,
  githubUrl: p.githubUrl,
  dashboardUrl: p.dashboardUrl,
  status: p.status,
  featured: p.featured,
}));
---

<PageLayout
  title="Portfolio"
  description="Data Analyst & Visualization Expert."
  currentPath="/"
>
  <Hero client:load />
  <ProjectCategories posts={proyectosSerializados} client:load />
  <Services client:visible />
  <Timeline client:visible />
  <Contact client:visible />
</PageLayout>
