---
import PageLayout from "@presentation/layouts/PageLayout.astro";
import Hero from "@presentation/components/sections/Hero.tsx";
import Experience from "@presentation/components/sections/Experience.tsx";
import Certifications from "@presentation/components/sections/Certifications.tsx";
import Skills from "@presentation/components/sections/Skills.tsx";
import ProjectCategories from "@presentation/components/sections/ProjectCategories.tsx";
import Contact from "@presentation/components/sections/Contact.tsx";
import { getCollection } from "astro:content";
import { ProjectMapper } from "@infrastructure/mappers/project.mapper";
import {
  serializeProjects,
  type SerializedProject,
} from "@presentation/components/sections/ProjectCategories.tsx";

let proyectosSerializados: SerializedProject[] = [];
try {
  const proyectosRaw = await getCollection("proyectos");
  proyectosSerializados = serializeProjects(
    ProjectMapper.toDomainArray(proyectosRaw)
  );
} catch {
  // Content collection "proyectos" does not exist yet
}
---

<PageLayout
  title="Horacio Laphitz — Data Analyst | Python, SQL & ML"
  description="Data Analyst especializado en Python, SQL y Machine Learning: pipelines de datos, dashboards en Power BI y modelos evaluados con métricas."
>
  <Hero client:load />
  <ProjectCategories posts={proyectosSerializados} client:load />
  <Skills client:visible />
  <Experience client:visible />
  <Certifications client:visible />
  <Contact client:visible />
</PageLayout>
