---
import PageLayout from "@presentation/layouts/PageLayout.astro";
import ProjectCategories from "@presentation/components/sections/ProjectCategories";
import { GitHubApiRepository } from "@infrastructure/repositories/github-api.repository";
import { ProjectCategory } from "@domain/entities/project.entity";

// Fetch projects from GitHub API, only data analysis related
const githubRepo = new GitHubApiRepository("HoracioLaphitz");
const proyectos = await githubRepo.findAll();

// Filter to show only Data Analysis projects
const proyectosDataAnalysis = proyectos.filter(
  (p) =>
    p.category === ProjectCategory.DataAnalysis &&
    !p.title.toLowerCase().includes("portfolio") &&
    !p.slug.includes("porfolio") &&
    !p.slug.includes("horaciolaphitz")
);

// Serialize for client
const proyectosSerializados = proyectosDataAnalysis.map((p) => ({
  slug: p.slug,
  title: p.title,
  description: p.description,
  category: p.category,
  tags: [...p.tags],
  publishDate: p.publishDate.toISOString(),
  author: p.author,
  githubUrl: p.githubUrl,
  dashboardUrl: p.dashboardUrl,
  status: p.status,
  featured: p.featured,
}));
---

<PageLayout
  title="Proyectos"
  description="Explora mis proyectos de análisis de datos y visualización."
  currentPath="/projects"
>
  <ProjectCategories posts={proyectosSerializados} client:visible />
</PageLayout>
