---
import PageLayout from "@presentation/layouts/PageLayout.astro";
import ProjectCategories, {
  serializeProjects,
} from "@presentation/components/sections/ProjectCategories.tsx";
import { getCollection } from "astro:content";
import { ProjectMapper } from "@infrastructure/mappers/project.mapper";

// Fetch projects from Astro Content Collection and serialize for the island
const proyectosRaw = await getCollection("proyectos", ({ data }) => !data.draft);
const proyectos = serializeProjects(ProjectMapper.toDomainArray(proyectosRaw));
---

<PageLayout
  title="Proyectos"
  description="Explora mis proyectos de análisis de datos y visualización."
>
  <ProjectCategories posts={proyectos} client:visible />
</PageLayout>
