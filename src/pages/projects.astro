---
import PageLayout from "@presentation/layouts/PageLayout.astro";
import ProjectCategories from "@presentation/components/sections/ProjectCategories";
import { getCollection } from "astro:content";
import { ProjectMapper } from "@infrastructure/mappers/project.mapper";

// Fetch projects from Astro Content Collection and map to domain entities
const proyectosRaw = await getCollection("proyectos");
const proyectos = ProjectMapper.toDomainArray(proyectosRaw);

// Serialize for client
const proyectosSerializados = proyectos.map((p) => ({
  slug: p.slug,
  title: p.title,
  description: p.description,
  category: p.category,
  tags: [...p.tags],
  publishDate: p.publishDate.toISOString(),
  author: p.author,
  githubUrl: p.githubUrl,
  dashboardUrl: p.dashboardUrl,
  status: p.status,
  featured: p.featured,
}));
---

<PageLayout
  title="Proyectos"
  description="Explora mis proyectos de análisis de datos y visualización."
  currentPath="/projects"
>
  <ProjectCategories posts={proyectosSerializados} client:visible />
</PageLayout>
