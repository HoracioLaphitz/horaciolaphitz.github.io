---
import PageLayout from "@presentation/layouts/PageLayout.astro";
---

<PageLayout title="¡Gracias!" description="Mensaje enviado correctamente.">
  <section class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center max-w-2xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-bold mb-6">
        Gracias por el mensaje!
      </h1>
      <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 mb-8">
        Te responderé lo antes posible.
      </p>
      <a
        href="/"
        class="inline-block px-8 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
      >
        Volver al inicio
      </a>
    </div>
  </section>
</PageLayout>
