---
import PageLayout from './PageLayout.astro';
import { slugify } from '@shared/slugify';

interface NotebookResource {
  name: string;
  path: string;
  description?: string;
}

interface Props {
  title: string;
  description: string;
  category: string;
  pubDate: Date;
  tags: string[];
  author: string;
  github?: string;
  dashboard?: string;
  currentPath: string;
  notebooks?: NotebookResource[];
  projectSlug?: string;
}

const { title, description, category, pubDate, tags, author, github, dashboard, currentPath, notebooks, projectSlug } = Astro.props;

const siteUrl = "https://horaciolaphitz.github.io";
const articleUrl = new URL(currentPath, siteUrl).href;
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  articleSection: category,
  datePublished: pubDate.toISOString(),
  keywords: tags.join(", "),
  url: articleUrl,
  mainEntityOfPage: { "@type": "WebPage", "@id": articleUrl },
  author: { "@type": "Person", name: author, url: siteUrl },
  publisher: { "@type": "Person", name: author, url: siteUrl },
};
---

<PageLayout title={title} description={description} currentPath={currentPath} type="article">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
  <article class="article-layout">
    <!-- Header estilo NYT -->
    <header class="article-header">
      <div class="article-header-content">
        <!-- Categoría y fecha -->
        <div class="article-meta">
          <span class="article-category">{category}</span>
          <span class="article-divider">|</span>
          <time class="article-date">
            {pubDate.toLocaleDateString('es-AR', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        </div>

        <!-- Título principal -->
        <h1 class="article-title">{title}</h1>

        <!-- Descripción/Bajada -->
        <p class="article-description">{description}</p>

        <!-- Autor -->
        <div class="article-author">
          <span class="author-label">Por</span>
          <span class="author-name">{author}</span>
        </div>

        <!-- Tags -->
        <div class="article-tags">
          {tags.map((tag) => (
            <span class="article-tag">{tag}</span>
          ))}
        </div>

        <!-- Acciones -->
        {(github || dashboard || (notebooks && notebooks.length > 0)) && (
          <div class="article-actions">
            {github && (
              <a
                href={github}
                target="_blank"
                rel="noopener noreferrer"
                class="article-action article-action-secondary"
              >
                <svg class="action-icon" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                </svg>
                Ver código
              </a>
            )}
            {dashboard && (
              <a
                href={dashboard}
                target="_blank"
                rel="noopener noreferrer"
                class="article-action article-action-primary"
              >
                <svg class="action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
                Ver dashboard
              </a>
            )}
            {notebooks && projectSlug && notebooks.map((notebook) => (
              <a
                href={`/proyectos/${projectSlug}/notebook/${slugify(notebook.name)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="article-action article-action-secondary"
              >
                <svg class="action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s4.332.477 5.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
                Ver notebook: {notebook.name}
              </a>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- Contenido del artículo -->
    <div class="article-body">
      <div class="article-content">
        <slot />
      </div>
    </div>
  </article>
</PageLayout>

<style>
  .article-layout {
    min-height: 100vh;
  }

  /* Header estilo NYT */
  .article-header {
    max-width: 680px;
    margin: 0 auto;
    padding: 3rem 1.5rem 2rem;
  }

  .article-header-content {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .article-category {
    color: var(--color-accent);
    font-weight: 600;
  }

  .article-divider {
    color: var(--color-muted);
  }

  .article-date {
    color: var(--color-muted);
  }

  .article-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-text);
    margin: 0 0 1.5rem 0;
    font-family: 'Georgia', 'Times New Roman', serif;
  }

  .article-description {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--color-muted);
    margin: 0 0 1.5rem 0;
    font-weight: 400;
  }

  .article-author {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
  }

  .author-label {
    color: var(--color-muted);
  }

  .author-name {
    color: var(--color-text);
    font-weight: 500;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .article-tag {
    font-size: 0.8125rem;
    padding: 0.25rem 0.75rem;
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    font-weight: 500;
  }

  .article-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .article-action {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 0.375rem;
    transition: all 0.2s;
    text-decoration: none;
  }

  .article-action-primary {
    background: var(--color-accent);
    color: white;
    border: 1px solid var(--color-accent);
  }

  .article-action-primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }

  .article-action-secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .article-action-secondary:hover {
    background: var(--color-surface);
    border-color: var(--color-accent);
  }

  .action-icon {
    width: 1.125rem;
    height: 1.125rem;
  }

  /* Cuerpo del artículo */
  .article-body {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .article-content {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  /* Tipografía estilo NYT */
  .article-content :global(h2) {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 2.5rem 0 1rem;
    color: var(--color-text);
    font-family: 'Georgia', 'Times New Roman', serif;
  }

  .article-content :global(h3) {
    font-size: 1.375rem;
    font-weight: 600;
    line-height: 1.4;
    margin: 2rem 0 0.75rem;
    color: var(--color-text);
  }

  .article-content :global(h4) {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.5;
    margin: 1.5rem 0 0.5rem;
    color: var(--color-text);
  }

  .article-content :global(p) {
    margin: 0 0 1.5rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .article-content :global(li) {
    margin: 0.5rem 0;
  }

  .article-content :global(blockquote) {
    margin: 2rem 0;
    padding-left: 1.5rem;
    border-left: 3px solid var(--color-accent);
    font-style: italic;
    color: var(--color-muted);
  }

  .article-content :global(code) {
    font-family: 'Courier New', monospace;
    font-size: 0.9em;
    background: var(--color-surface);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
  }

  .article-content :global(pre) {
    margin: 1.5rem 0;
    padding: 1.5rem;
    background: var(--color-surface);
    border-radius: 0.5rem;
    overflow-x: auto;
  }

  .article-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .article-content :global(strong) {
    font-weight: 600;
    color: var(--color-text);
  }

  .article-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .article-content :global(a:hover) {
    color: var(--color-accent-hover);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .article-header {
      padding: 2rem 1rem 1.5rem;
    }

    .article-title {
      font-size: 1.75rem;
    }

    .article-description {
      font-size: 1.125rem;
    }

    .article-body {
      padding: 1.5rem 1rem 3rem;
    }

    .article-content {
      font-size: 1.0625rem;
    }
  }
</style>
