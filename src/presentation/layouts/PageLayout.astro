---
import Layout from "./Layout.astro";
import Navigation from "../components/layout/Navigation.tsx";

export interface Props {
  title: string;
  description: string;
  type?: "website" | "article" | "profile";
  canonical?: string;
}

const { title, description, type, canonical } = Astro.props;
---

<Layout
  title={title}
  description={description}
  type={type}
  canonical={canonical}
>
  <Navigation client:load />

  <main class="pt-14 min-h-screen bg-skin-primary">
    <slot />
  </main>
</Layout>
