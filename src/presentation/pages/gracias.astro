---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="Gracias"
  description="Mensaje enviado correctamente"
  currentPath="/gracias"
>
  <section
    class="min-h-screen flex items-center justify-center bg-skin-primary"
  >
    <div class="container mx-auto px-6 max-w-2xl text-center">
      <div
        class="bg-skin-secondary rounded-2xl p-12 border border-skin-border shadow-lg"
      >
        <div
          class="w-20 h-20 bg-emerald-500/10 rounded-full flex items-center justify-center mx-auto mb-6"
        >
          <svg
            class="w-10 h-10 text-emerald-600 dark:text-emerald-500"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M5 13l4 4L19 7"></path>
          </svg>
        </div>

        <h1 class="text-3xl sm:text-4xl font-bold text-skin-text mb-4">
          Mensaje Enviado
        </h1>

        <p class="text-lg text-skin-muted mb-8">
          Gracias por el mensaje. Responderé lo antes posible. Saludos!
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/"
            class="inline-flex items-center justify-center px-8 py-3 bg-brand-primary text-skin-primary font-semibold rounded-lg hover:bg-brand-hover transition-all duration-300 shadow-md hover:shadow-lg"
          >
            Volver al Inicio
          </a>
          <a
            href="/proyectos"
            class="inline-flex items-center justify-center px-8 py-3 border-2 border-skin-text text-skin-text font-medium rounded-lg hover:bg-skin-text hover:text-skin-primary transition-all duration-300"
          >
            Ver Proyectos
          </a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
