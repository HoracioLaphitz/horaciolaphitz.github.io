---
import PageLayout from "../layouts/PageLayout.astro";
import Hero from "../components/sections/Hero.tsx";
import Timeline from "../components/sections/Timeline.tsx";
import Services from "../components/sections/Services.tsx";
import ProjectCategories from "../components/sections/ProjectCategories.tsx";
import Contact from "../components/sections/Contact.tsx";
import { getCollection } from "astro:content";
import { ProjectMapper } from "../../infrastructure/mappers/project.mapper";

// Fetch projects from Astro Content Collection and map to domain entities
const proyectosRaw = await getCollection("proyectos");
const proyectos = ProjectMapper.toDomainArray(proyectosRaw);
---

<PageLayout
  title="Portfolio"
  description="Data Analyst & Visualization Expert."
  currentPath="/"
>
  <Hero client:load />
  <Timeline client:visible />
  <ProjectCategories posts={proyectos} client:visible />
  <Services client:visible />
  <Contact client:visible />
</PageLayout>
