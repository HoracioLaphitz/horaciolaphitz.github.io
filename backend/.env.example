# ── Django ──────────────────────────────────────────
DJANGO_DEBUG=False
API_SECRET_KEY=<generated-with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">
ALLOWED_HOSTS=.vercel.app
ALLOWED_ORIGINS=https://*.vercel.app

# ── Database (Supabase PostgreSQL) ──────────────────
POSTGRES_URL=postgres://user:password@host:6543/postgres?sslmode=require

# ── Django fallbacks (only if POSTGRES_URL is not set) ──
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Cache ───────────────────────────────────────────
CACHE_TTL_SECONDS=3600

# ── Rate Limiting ────────────────────────────────────
# THROTTLE_RATE_CONTACT=5/hour
